---
import Base from '../layouts/Base.astro';
import { projects } from '../data/projects.js';
---

<Base title="Ethan Justice — Cloud Security Analyst" path="/">
  <div class="wrap">
    <section class="hero prose">
      <h1>Ethan Justice</h1>
      <p class="lede">
        Cloud security analyst. I govern cloud environments for a Fortune 500
        insurer by day, and run my own infrastructure like production by night.
      </p>
    </section>

    <ul class="stats" aria-label="At a glance">
      <li><strong>1,100+</strong> GCP projects brought under governance</li>
      <li><strong>11</strong> releases of my Android fork shipped</li>
      <li><strong>13-container</strong> stack, restore-tested backups</li>
      <li><strong>5th of 160</strong> — DOE CyberForce</li>
    </ul>

    <section class="selftest" data-selftest>
      <h2 class="section-label">this page is the first exhibit</h2>
      <p class="selftest-intro">
        I could tell you I take this seriously. Instead: attack it. Every button
        below runs a real attack against this page, in your browser, right now.
        Nothing is simulated and none of the verdicts are written by me — they
        are the browser refusing, and reporting why.
      </p>

      <div class="map-controls">
        <button class="map-btn" type="button" data-atk="all">run all →</button>
        <span class="sep"></span>
        <button class="map-btn" type="button" data-atk="eval">eval()</button>
        <button class="map-btn" type="button" data-atk="fn">new Function()</button>
        <button class="map-btn" type="button" data-atk="inline">inject a script</button>
        <button class="map-btn" type="button" data-atk="style">inject a style</button>
        <button class="map-btn" type="button" data-atk="cdn">load a CDN</button>
        <button class="map-btn" type="button" data-atk="fetch">phone home</button>
      </div>

      <ol class="atk-list" data-atk-list aria-live="polite"></ol>

      <div class="policy" data-policy hidden>
        <p class="possess-label">the policy your browser reports enforcing, read from its own violation event</p>
        <code data-policy-text></code>
      </div>

      <p class="selftest-intro">
        And here is everything this page fetched to show you itself. Not a claim
        in a footer — your browser's own record, counted against this domain.
      </p>

      <div class="manifest" data-manifest>
        <div class="manifest-head">
          <span><b data-mf-count>—</b> requests</span>
          <span><b data-mf-weight>—</b> transferred</span>
          <span class="manifest-verdict" data-mf-verdict>counting…</span>
        </div>
        <ul class="manifest-list" data-mf-list></ul>
      </div>
    </section>

    <h2 class="section-label">projects</h2>
    <div class="project-grid">
      {
        projects.map((p) => (
          <a class="card" href={`/projects/${p.slug}/`}>
            <h3>{p.title}</h3>
            <p>{p.blurb}</p>
            <ul class="tags" aria-label="Stack">
              {p.tags.map((t) => (
                <li>{t}</li>
              ))}
            </ul>
            <span class="arrow">{p.demo} →</span>
          </a>
        ))
      }
    </div>
  </div>

  <script is:inline src="/js/selftest.js" defer></script>
  <script is:inline src="/js/manifest.js" defer></script>
</Base>
